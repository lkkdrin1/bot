async def mailing_message(update: Update, context: ContextTypes.DEFAULT_TYPE):
    """Получение текста рассылки"""
    context.user_data['mailing_text'] = update.message.text
    
    await update.message.reply_text(
        "👥 <b>Получатели</b>\n\n"
        "Введите юзернеймы через пробел:\n"
        "Пример: @user1 @user2 @user3\n\n"
        "Или 'отмена' для выхода:",
        parse_mode='HTML'
    )
    return MAILING_USERNAMES

async def mailing_usernames(update: Update, context: ContextTypes.DEFAULT_TYPE):
    """Запуск рассылки"""
    text = update.message.text.strip()
    
    if text.lower() == 'отмена':
        await update.message.reply_text("❌ Рассылка отменена")
        return ConversationHandler.END
    
    # Парсим юзернеймы
    usernames = re.findall(r'@(\w+)', text)
    
    if not usernames:
        await update.message.reply_text("❌ Нет юзернеймов. Попробуйте снова:")
        return MAILING_USERNAMES
    
    user_id = update.effective_user.id
    message_text = context.user_data['mailing_text']
    
    # Получаем клиент
    client = await session_manager.load_session(user_id)
    
    if not client:
        await update.message.reply_text("❌ Сессия не загружена")
        return ConversationHandler.END
    
    # Стартуем рассылку
    await update.message.reply_text(
        f"📨 <b>Запуск рассылки</b>\n\n"
        f"Получателей: {len(usernames)}\n"
        f"Текст: {message_text[:50]}...",
        parse_mode='HTML'
    )
    
    # Результаты
    results = {
        'success': 0, 'failed': 0, 'blocked': 0,
        'deactivated': 0, 'flood_wait': 0, 'details': []
    }
    
    status_msg = await update.message.reply_text("🔄 Прогресс: 0%")
    
    for i, username in enumerate(usernames):
        try:
            # Получаем пользователя
            try:
                entity = await client.get_entity(username)
            except ValueError:
                results['failed'] += 1
                results['details'].append(f"❌ @{username} - неверный юзернейм")
                continue
            
            # Отправляем сообщение
            await client.send_message(entity, message_text)
            
            results['success'] += 1
            results['details'].append(f"✅ @{username} - успешно")
            
        except FloodWaitError as e:
            wait = e.seconds
            results['flood_wait'] += 1
            results['details'].append(f"⚠️ @{username} - флуд, ожидание {wait}с")
            
            if i % 5 == 0:
                await update.message.reply_text(f"⏱ Флуд-контроль: ждем {wait}с")
            
            await asyncio.sleep(wait)
            
        except Exception as e:
            error = str(e)
            if "USER_IS_BLOCKED" in error:
                results['blocked'] += 1
                results['details'].append(f"❌ @{username} - заблокировал")
            elif "USER_IS_DEACTIVATED" in error:
                results['deactivated'] += 1
                results['details'].append(f"❌ @{username} - удален")
            else:
                results['failed'] += 1
                results['details'].append(f"❌ @{username} - {error[:50]}")
        
        # Обновляем прогресс
        if (i + 1) % 5 == 0 or i == len(usernames) - 1:
            progress = int((i + 1) / len(usernames) * 100)
            await status_msg.edit_text(f"🔄 Прогресс: {progress}%")
    
    # Отчет
    report = (
        f"📊 <b>Отчет о рассылке</b>\n\n"
        f"✅ Успешно: {results['success']}\n"
        f"❌ Неудачно: {results['failed']}\n"
        f"🚫 Заблокировали: {results['blocked']}\n"
        f"💀 Удалены: {results['deactivated']}\n"
        f"⏱ Флуд: {results['flood_wait']}\n\n"
    )
    
    if results['details']:
        report += "<b>Детали (первые 10):</b>\n"
        for detail in results['details'][:10]:
            report += f"{detail}\n"
        
        if len(results['details']) > 10:
            report += f"... и еще {len(results['details']) - 10}"
    
    await update.message.reply_text(report, parse_mode='HTML')
    
    # Возвращаемся в меню
    context.user_data.clear()
    await show_main_menu(update, context)
    return ConversationHandler.END

async def add_profit(update: Update, context: ContextTypes.DEFAULT_TYPE):
    """Добавление профита"""
    user_id = update.effective_user.id
    
    if not user_data.get(user_id, {}).get("authenticated", False):
        await update.message.reply_text("❌ Авторизуйтесь")
        return
    
    try:
        amount = int(context.args[0])
        user_data[user_id]["profits"].append(amount)
        user_data[user_id]["total_cash"] += amount
        await update.message.reply_text(f"✅ Профит {amount} руб. добавлен!")
    except:
        await update.message.reply_text("Использование: /profit [сумма]")

async def check_session(update: Update, context: ContextTypes.DEFAULT_TYPE):
    """Проверка сессии"""
    user_id = update.effective_user.id
    
    session_file = session_manager.find_session_file(user_id)
    
    if session_file:
        valid = session_manager.validate_session_file(session_file)
        
        text = (
            f"📁 <b>Информация о сессии</b>\n\n"
            f"Файл: {session_file}\n"
            f"Корректен: {'✅' if valid else '❌'}\n"
            f"Загружена: {'✅' if user_id in session_manager.active_sessions else '❌'}\n"
            f"Папка: {os.path.abspath(SESSIONS_DIR)}"
        )
        
        if valid and user_id in session_manager.active_sessions:
            client = session_manager.active_sessions[user_id]
            me = await client.get_me()
            text += f"\n\nАккаунт: @{me.username} (ID: {me.id})"
    else:
        text = (
            f"❌ <b>Сессия не найдена</b>\n\n"
            f"Папка: {os.path.abspath(SESSIONS_DIR)}\n"
            f"Ожидаемый файл: {user_id}.session"
        )
    
    await update.message.reply_text(text, parse_mode='HTML')


    await update.message.reply_text("❌ Отменено")
    return ConversationHandler.END

# ==================== ОСНОВНАЯ ФУНКЦИЯ ====================
def main():
    """Запуск бота"""
    # Проверка конфигурации
    if not check_config():
        return
    
    print("\n" + "="*50)
    print("🚀 ЗАПУСК БОТА")
    print("="*50)
    print(f"📁 Папка с сессиями: {os.path.abspath(SESSIONS_DIR)}")
    
    # Показываем найденные сессии
    session_files = list(Path(SESSIONS_DIR).glob("*.session"))
    if session_files:
        print(f"\n📂 Найденные сессии:")
        for f in session_files:
            size = os.path.getsize(f)
            print(f"   • {f.name} ({size} байт)")
    else:
        print(f"\n⚠️ В папке {SESSIONS_DIR} нет .session файлов")
        print(f"   Положите файл сессии в эту папку")
    
    print("\n" + "="*50)
    
    # Создаем приложение
    application = Application.builder().token(BOT_TOKEN).build()
    
    # ConversationHandler для авторизации
    auth_handler = ConversationHandler(
        entry_points=[CommandHandler('start', start)],
        states={ENTER_PASSWORD: [MessageHandler(filters.TEXT & ~filters.COMMAND, check_password)]},
        fallbacks=[CommandHandler('cancel', cancel)],
    )
    
    # ConversationHandler для рассылки
    mailing_handler = ConversationHandler(
        entry_points=[CallbackQueryHandler(button_handler, pattern='^mailing$')],
        states={
            MAILING_MESSAGE: [MessageHandler(filters.TEXT & ~filters.COMMAND, mailing_message)],
            MAILING_USERNAMES: [MessageHandler(filters.TEXT & ~filters.COMMAND, mailing_usernames)],
        },
        fallbacks=[CommandHandler('cancel', cancel)],
        allow_reentry=True,
    )
    
    # Добавляем обработчики
    application.add_handler(auth_handler)
    application.add_handler(mailing_handler)
    application.add_handler(CallbackQueryHandler(button_handler))
    application.add_handler(CommandHandler("profit", add_profit))
